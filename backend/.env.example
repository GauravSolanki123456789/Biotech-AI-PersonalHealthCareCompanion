# Copy to .env and set real values. Placeholder OPENAI_API_KEY keeps the API up;
# chat returns retrieved PatientRecord text until a real key is set.
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Comma-separated browser origins for CORS (Next.js dev server by default)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
